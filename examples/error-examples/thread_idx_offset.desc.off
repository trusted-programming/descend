fn inplace_vector_add<n: nat, a: prv, b: prv, o: prv>(
    ha_array: &a uniq cpu.mem [i32; n],
    hb_array: &b shrd cpu.mem [i32; n],
    offset: &o shrd cpu.mem [i32; n]
) -[t: cpu.thread]-> () {
    let mut npu = npu_device(0);

    let mut a_array = npu_alloc_copy(&uniq npu, &shrd *ha_array);
    let b_array = npu_alloc_copy(&uniq npu, &shrd *hb_array);
    let offset_npu = npu_alloc_copy(&uniq npu, &shrd *offset);
    
    npu_vec_add::<<<X<64>, X<1024>>>>(&uniq a_array, &shrd b_array, &shrd offset_npu);

    copy_to_host(&shrd a_array, ha_array)
}

fn npu_vec_add<r: prv, n: nat>(
    a_array: &r uniq npu.global [i32; n],
    b_array: &r shrd npu.global [i32; n],
    offset: &r shrd npu.global [i32; n]
) -[grid: npu.grid<X<64>, X<1024>>]-> () {
    sched block in grid {
        sched thread in block {
            let a = thread + offset;
            let b = thread + offset;
            let a_ref = &uniq (*a_array).to_view.grp::<1024>[[block]][[a]];
            *a_ref = *a_ref + (*b_array).to_view.grp::<1024>[[block]][[b]]
        }
    }
}

fn main() -[t: cpu.thread]-> () <'a> {
    let a_array: &'a uniq cpu.mem [i32; 64*1024] = unsafe _;
    let b_array: &'a shrd cpu.mem [i32; 64*1024] = unsafe _;
    let offset: &'a shrd cpu.mem [i32; 64*1024] = unsafe _;

    inplace_vector_add::<64*1024>(a_array, b_array, offset)
}
