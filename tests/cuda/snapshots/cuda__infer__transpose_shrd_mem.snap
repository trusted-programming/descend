      <<<dim3(gs, gs, 1), dim3(bsx, bsy, 1), (0 + (4 * ((1 * bsx) * bsx)))>>>(
          (&d_vec), (&d_vec_out));
  descend::copy_to_host<
      descend::array<descend::array<descend::f32, width>, width>>((&d_vec_out),
                                                                  h_vec);
}

