template <std::size_t gs, std::size_t bsx, std::size_t bsy, std::size_t width>
__host__ auto transpose(descend::f32 *const h_vec) -> void {
  auto gpu = descend::gpu_device(0);
  const auto d_vec = descend::gpu_alloc_copy<
      descend::array<descend::array<descend::f32, width>, width>>((&gpu),
